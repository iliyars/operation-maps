<Window x:Class="OperationMaps.Wpf.Features.Components.AddComponent.AddComponentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OperationMaps.Wpf.Features.Components.AddComponent"
        Title="Ввод данных компонента"
        Width="680"
        Height="680"
        MinWidth="600"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgAppBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgPanelBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel>
                <TextBlock Text="Ввод данных компонента"
                        Style="{StaticResource TitleText}"/>
                <StackPanel Orientation="Horizontal"
                        Margin="0,4,0,0">
                    <TextBlock Text="{Binding ComponentRawName}"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text=" — "
                            Style="{StaticResource PositionsText}"/>
                    <TextBlock Text="{Binding ComponentPositions}"
                            Style="{StaticResource PositionsText}"/>
                </StackPanel>
                <!-- Step indicator -->
                <StackPanel Orientation="Horizontal"
                        Margin="0,10,0,0"
                        Visibility="{Binding HasStep1, Converter={StaticResource BoolToVis}}">
                    <Border CornerRadius="10"
                            Padding="8,3"
                            Margin="0,0,6,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="{DynamicResource AccentBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep2}"
                                            Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource BgHoverBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="1. Форма 4"
                                FontSize="11"
                                FontWeight="Medium">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStep2}"
                                                Value="True">
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource TextMutedBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <Border CornerRadius="10"
                            Padding="8,3">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="{DynamicResource BgHoverBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep2}"
                                            Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="2. Собственная форма"
                                FontSize="11"
                                FontWeight="Medium">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource TextMutedBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStep2}"
                                                Value="True">
                                            <Setter Property="Foreground"
                                                    Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Loading -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                HorizontalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Загрузка..."
                    Style="{StaticResource MutedText}"
                    FontSize="14"/>
        </StackPanel>

        <!-- Body -->
        <Grid Grid.Row="1"
                Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">

            <!-- Step 1: Family + Form 4 -->
            <ScrollViewer Padding="20,16"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}">
                <StackPanel>

                    <TextBlock Text="Семейство"
                            Style="{StaticResource SectionLabel}"
                            Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FamilyName, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="{Binding FamilyAlreadyKnown}"
                             Margin="0,0,0,4"/>
                    <TextBlock Text="Семейство определено автоматически из наименования"
                               FontSize="11"
                            Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,0,0,16"
                               Visibility="{Binding FamilyAlreadyKnown, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="Семейство не распознано — название заполнено по имени компонента, при необходимости измените"
                               FontSize="11"
                            Foreground="{DynamicResource StatusWarningBrush}"
                               Margin="0,0,0,16"
                               Visibility="{Binding FamilyAlreadyKnown, Converter={StaticResource InverseBoolToVis}}"/>

                    <Separator Margin="0,0,0,16"/>

                    <TextBlock Text="Параметры Формы 4 (одинаковы для всего семейства)"
                               FontSize="13"
                            FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding Form4Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:WizardParameterRowVm}">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="6,4"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- Step 2: Own form -->
            <ScrollViewer Padding="20,16"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsStep2, Converter={StaticResource BoolToVis}}">
                <StackPanel>

                    <TextBlock Text="Собственная форма компонента"
                            Style="{StaticResource SectionLabel}"
                            Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding OwnFormOptions}"
                              SelectedItem="{Binding SelectedOwnForm}"
                              DisplayMemberPath="Display"
                              Margin="0,0,0,16"/>

                    <Separator Margin="0,0,0,16"
                               Visibility="{Binding SelectedOwnForm, Converter={StaticResource NullToVis}}"/>

                    <StackPanel Visibility="{Binding SelectedOwnForm, Converter={StaticResource NullToVis}}">
                        <TextBlock Text="Параметры выбранной формы"
                                   FontSize="13"
                                FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,12"/>

                        <!-- Column headers, mirroring the row layout below -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition>
                                    <ColumnDefinition.Style>
                                        <Style TargetType="ColumnDefinition">
                                            <Setter Property="Width" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding OwnFormShowsPins}" Value="True">
                                                    <Setter Property="Width" Value="120"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ColumnDefinition.Style>
                                </ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"/>
                            <TextBlock Grid.Column="1"
                                       Text="Параметр по НТД"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="2"
                                       Text="№ выводов"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Visibility="{Binding OwnFormShowsPins, Converter={StaticResource BoolToVis}}"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding OwnFormRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:WizardParameterRowVm}">
                                    <StackPanel Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition>
                                                    <ColumnDefinition.Style>
                                                        <Style TargetType="ColumnDefinition">
                                                            <Setter Property="Width" Value="0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShowPins}" Value="True">
                                                                    <Setter Property="Width" Value="120"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ColumnDefinition.Style>
                                                </ColumnDefinition>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding DisplayName}"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="6,4"
                                                     Margin="0,0,8,0"/>
                                            <TextBox Grid.Column="2"
                                                     Text="{Binding PinsValue, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="6,4"
                                                     ToolTip="Номера выводов"
                                                     Visibility="{Binding ShowPins, Converter={StaticResource BoolToVis}}"/>
                                        </Grid>

                                        <!-- Optional second-value row, e.g. Form 64's second supply voltage -->
                                        <StackPanel Margin="0,6,0,0"
                                                    Visibility="{Binding CanHaveOptionalRow, Converter={StaticResource BoolToVis}}">

                                            <Button Command="{Binding AddOptionalRowCommand}"
                                                    Style="{StaticResource GhostButton}"
                                                    HorizontalAlignment="Left"
                                                    Padding="0"
                                                    Visibility="{Binding IsOptionalRowVisible, Converter={StaticResource InverseBoolToVis}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE710;" Style="{StaticResource IconText}"
                                                               FontSize="10" Foreground="{DynamicResource AccentBrush}"
                                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="Добавить второе напряжение"
                                                               FontSize="11" Foreground="{DynamicResource AccentBrush}"/>
                                                </StackPanel>
                                            </Button>

                                            <Border Background="{DynamicResource BgHoverBrush}"
                                                    CornerRadius="6" Padding="8"
                                                    Visibility="{Binding IsOptionalRowVisible, Converter={StaticResource BoolToVis}}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition>
                                                            <ColumnDefinition.Style>
                                                                <Style TargetType="ColumnDefinition">
                                                                    <Setter Property="Width" Value="0"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ShowPins}" Value="True">
                                                                            <Setter Property="Width" Value="120"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ColumnDefinition.Style>
                                                        </ColumnDefinition>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="второе напряжение"
                                                               VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding OptionalValue, UpdateSourceTrigger=PropertyChanged}"
                                                             Padding="6,4" Margin="0,0,8,0"/>
                                                    <TextBox Grid.Column="2"
                                                             Text="{Binding OptionalPinsValue, UpdateSourceTrigger=PropertyChanged}"
                                                             Padding="6,4"
                                                             ToolTip="Номера выводов"
                                                             Visibility="{Binding ShowPins, Converter={StaticResource BoolToVis}}"/>
                                                    <Button Grid.Column="3"
                                                            Command="{Binding RemoveOptionalRowCommand}"
                                                            Style="{StaticResource IconButton}"
                                                            Margin="6,0,0,0"
                                                            ToolTip="Удалить">
                                                        <TextBlock Text="&#xE711;" Style="{StaticResource IconText}"
                                                                   FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgPanelBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource StatusWarningBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}"/>

                <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                    <Button Content="Назад"
                            Style="{StaticResource OutlineButton}"
                            Command="{Binding GoBackCommand}"
                            Height="36"
                            Padding="18,0"
                            MinWidth="80"
                            Margin="0,0,8,0"
                            VerticalContentAlignment="Center"
                            Visibility="{Binding HasStep1, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="Далее"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding GoNextCommand}"
                            Padding="14,8"
                            Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}"
                            Padding="14,8"
                            Visibility="{Binding IsStep2, Converter={StaticResource BoolToVis}}">
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"
                                            Value="Сохранить"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSaving}"
                                                Value="True">
                                            <Setter Property="Text"
                                                    Value="Сохранение..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
