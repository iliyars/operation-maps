<UserControl x:Class="OperationMaps.Wpf.Features.Components.ComponentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:OperationMaps.Wpf.Features.Components"
             mc:Ignorable="d">

    <UserControl.Resources>

        <Style x:Key="StatusBadge"
                TargetType="Border">
            <Setter Property="CornerRadius"
                    Value="4"/>
            <Setter Property="Padding"
                    Value="6,2"/>
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
        </Style>

        <Style x:Key="FilterTab"
                TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="0,0,0,2"/>
            <Setter Property="BorderBrush"
                    Value="Transparent"/>
            <Setter Property="Padding"
                    Value="12,8"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Foreground"
                    Value="#666666"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Foreground"
                                        Value="#2B579A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- search + filter tabs -->
            <RowDefinition Height="*"/>
            <!-- list + detail        -->
        </Grid.RowDefinitions>

        <!-- SEARCH + FILTER TABS -->
        <Border Grid.Row="0"
                BorderBrush="#EEEEEE"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Search -->
                <Border Grid.Row="0"
                        Background="#FAFAFA"
                        Padding="12,8">
                    <Border Background="White"
                            BorderBrush="#DCDCDC"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="8,0"
                            Height="30"
                            MaxWidth="320"
                            HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE71E;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="#AAAAAA"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     VerticalAlignment="Center"
                                     FontSize="13"/>
                        </Grid>
                    </Border>
                </Border>

                <!-- Filter tabs -->
                <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="8,0">
                    <Button Style="{StaticResource FilterTab}"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="{x:Static local:ComponentFilter.All}">
                        <TextBlock>
                            <Run Text="Все "/><Run Text="("/><Run Text="{Binding CountAll, Mode=OneWay}"/><Run Text=")"/>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource FilterTab}"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="{x:Static local:ComponentFilter.Matched}">
                        <TextBlock>
                            <Run Text="Найдены "/><Run Text="("/><Run Text="{Binding CountMatched, Mode=OneWay}"/><Run Text=")"/>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource FilterTab}"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="{x:Static local:ComponentFilter.Unresolved}">
                        <TextBlock>
                            <Run Text="Не найдены "/><Run Text="("/><Run Text="{Binding CountUnresolved, Mode=OneWay}"/><Run Text=")"/>
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LIST + DETAIL -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="300"
                        MinWidth="200"
                        MaxWidth="480"/>
            </Grid.ColumnDefinitions>

            <!-- List -->
            <ListView Grid.Column="0"
                      ItemsSource="{Binding FilteredComponents}"
                      SelectedItem="{Binding SelectedComponent}"
                      SelectionMode="Single"
                      BorderThickness="0"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Позиции"
                                Width="130">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type local:ProjectComponentVm}">
                                    <TextBlock Text="{Binding Positions}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               ToolTip="{Binding Positions}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Наименование"
                                Width="240">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type local:ProjectComponentVm}">
                                    <TextBlock Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Name}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Тип"
                                Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type local:ProjectComponentVm}">
                                    <TextBlock Text="{Binding TypeName}"
                                            Foreground="#555555"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Семейство"
                                Width="130">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type local:ProjectComponentVm}">
                                    <TextBlock Text="{Binding FamilyName}"
                                            Foreground="#555555"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Статус"
                                Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type local:ProjectComponentVm}">
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border"
                                                    BasedOn="{StaticResource StatusBadge}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MatchStatus}"
                                                            Value="Matched">
                                                        <Setter Property="Background"
                                                                Value="#E6F4EA"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MatchStatus}"
                                                            Value="FamilyFound">
                                                        <Setter Property="Background"
                                                                Value="#E8F0FE"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MatchStatus}"
                                                            Value="Unresolved">
                                                        <Setter Property="Background"
                                                                Value="#FFF3CD"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6"
                                                    Height="6"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,5,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                                    Value="Matched">
                                                                <Setter Property="Fill"
                                                                        Value="#34A853"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                                    Value="FamilyFound">
                                                                <Setter Property="Fill"
                                                                        Value="#4285F4"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                                    Value="Unresolved">
                                                                <Setter Property="Fill"
                                                                        Value="#F9A825"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock VerticalAlignment="Center"
                                                    FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                                    Value="Matched">
                                                                <Setter Property="Text"
                                                                        Value="Найден"/>
                                                                <Setter Property="Foreground"
                                                                        Value="#1E7E34"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                                    Value="FamilyFound">
                                                                <Setter Property="Text"
                                                                        Value="Семейство"/>
                                                                <Setter Property="Foreground"
                                                                        Value="#1A73E8"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                                    Value="Unresolved">
                                                                <Setter Property="Text"
                                                                        Value="Не найден"/>
                                                                <Setter Property="Foreground"
                                                                        Value="#856404"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Divider -->
            <Border Grid.Column="1"
                    Background="#EEEEEE"/>

            <!-- Detail panel -->
            <Grid Grid.Column="2"
                    Background="#FAFAFA">

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding SelectedComponent,
                                Converter={StaticResource NotNullToVis}}">
                    <TextBlock Text="&#xE9CE;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="32"
                               Foreground="#CCCCCC"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Выберите компонент"
                               Foreground="#AAAAAA"
                               FontSize="13"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Component detail -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding SelectedComponent,
                                  Converter={StaticResource NullToVis}}">
                    <StackPanel Margin="16"
                            DataContext="{Binding SelectedComponent}">

                        <TextBlock Text="{Binding Name}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1A1A2E"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding Positions}"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="#666666"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="ПАРАМЕТРЫ ПО НТД"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#888888"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Загрузка..."
                                   FontSize="12"
                                   Foreground="#AAAAAA"
                                   Visibility="{Binding IsLoadingNtd,
                                       Converter={StaticResource BoolToVis}}"/>

                        <TextBlock Text="Семейство не найдено в каталоге"
                                   FontSize="12"
                                   Foreground="#AAAAAA"
                                   FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsLoadingNtd}"
                                                        Value="False"/>
                                                <Condition Binding="{Binding NtdLoaded}"
                                                        Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility"
                                                    Value="{Binding NtdValues.Count,
                                                        Converter={StaticResource NotNullToVis}}"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding NtdValues}"
                                      Visibility="{Binding NtdLoaded,
                                          Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:NtdParameterVm}">
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DisplayName}"
                                                   FontSize="12"
                                                   Foreground="#444444"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   FontSize="12"
                                                   FontFamily="Consolas"
                                                   Foreground="#2B579A"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
