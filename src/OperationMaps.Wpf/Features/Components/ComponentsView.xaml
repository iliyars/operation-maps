<UserControl x:Class="OperationMaps.Wpf.Features.Components.ComponentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:OperationMaps.Wpf.Features.Components"
             mc:Ignorable="d"
             Background="{DynamicResource BgAppBrush}">

    <UserControl.Resources>

        <Style x:Key="StatusBadge"
                TargetType="Border">
            <Setter Property="CornerRadius"
                    Value="4"/>
            <Setter Property="Padding"
                    Value="6,2"/>
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
        </Style>

        <Style x:Key="FilterTab"
                TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="0,0,0,2"/>
            <Setter Property="BorderBrush"
                    Value="Transparent"/>
            <Setter Property="Padding"
                    Value="12,8"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- SEARCH + FILTER TABS -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Search -->
                <Border Grid.Row="0"
                        Background="{DynamicResource BgPanelBrush}"
                        Padding="12,8">
                    <Border Background="{DynamicResource BgInputBrush}"
                            BorderBrush="{DynamicResource BorderInputBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,0"
                            Height="30"
                            MaxWidth="320"
                            HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE71E;"
                                       Style="{StaticResource IconText}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       Margin="0,0,6,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     VerticalAlignment="Center"
                                     FontSize="13"/>
                        </Grid>
                    </Border>
                </Border>

                <!-- Filter tabs -->
                <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="8,0">
                    <Button Style="{StaticResource FilterTab}"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="{x:Static local:ComponentFilter.All}">
                        <TextBlock>
                            <Run Text="Все "/><Run Text="("/><Run Text="{Binding CountAll, Mode=OneWay}"/><Run Text=")"/>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource FilterTab}"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="{x:Static local:ComponentFilter.Matched}">
                        <TextBlock>
                            <Run Text="Найдены "/><Run Text="("/><Run Text="{Binding CountMatched, Mode=OneWay}"/><Run Text=")"/>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource FilterTab}"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="{x:Static local:ComponentFilter.Unresolved}">
                        <TextBlock>
                            <Run Text="Не найдены "/><Run Text="("/><Run Text="{Binding CountUnresolved, Mode=OneWay}"/><Run Text=")"/>
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LIST + DETAIL -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="300"
                        MinWidth="200"
                        MaxWidth="480"/>
            </Grid.ColumnDefinitions>

            <!-- List -->
            <ListView Grid.Column="0"
                      ItemsSource="{Binding FilteredComponents}"
                      SelectedItem="{Binding SelectedComponent}"
                      SelectionMode="Single"
                      BorderThickness="0"
                      Background="{DynamicResource BgAppBrush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment"
                                Value="Stretch"/>
                        <Setter Property="FocusVisualStyle"
                                Value="{x:Null}"/>
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Padding"
                                Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                            BorderThickness="0,0,0,1">
                                        <GridViewRowPresenter
                                            Columns="{Binding Path=View.Columns,
                                RelativeSource={RelativeSource AncestorType=ListView}}"
                                            Content="{TemplateBinding Content}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                Value="True">
                                            <Setter TargetName="Bd"
                                                    Property="Background"
                                                    Value="{DynamicResource BgHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected"
                                                Value="True">
                                            <Setter TargetName="Bd"
                                                    Property="Background"
                                                    Value="{DynamicResource BgActiveBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Позиции"
                                Width="130">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type local:ProjectComponentVm}">
                                    <TextBlock Text="{Binding Positions}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               ToolTip="{Binding Positions}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Наименование"
                                Width="220">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type local:ProjectComponentVm}">
                                    <TextBlock Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               ToolTip="{Binding Name}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Тип"
                                Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type local:ProjectComponentVm}">
                                    <TextBlock Text="{Binding TypeName}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Семейство"
                                Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type local:ProjectComponentVm}">
                                    <TextBlock Text="{Binding FamilyName}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Статус"
                                Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type local:ProjectComponentVm}">
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border"
                                                    BasedOn="{StaticResource StatusBadge}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MatchStatus}"
                                                            Value="Matched">
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource StatusSuccessBgBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MatchStatus}"
                                                            Value="FamilyFound">
                                                        <Setter Property="Background"
                                                                Value="#E8F0FE"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MatchStatus}"
                                                            Value="Unresolved">
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource StatusWarningBgBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6"
                                                    Height="6"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,5,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                                    Value="Matched">
                                                                <Setter Property="Fill"
                                                                        Value="{DynamicResource StatusSuccessBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                                    Value="FamilyFound">
                                                                <Setter Property="Fill"
                                                                        Value="#4285F4"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                                    Value="Unresolved">
                                                                <Setter Property="Fill"
                                                                        Value="{DynamicResource StatusWarningBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock VerticalAlignment="Center"
                                                    FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                                    Value="Matched">
                                                                <Setter Property="Text"
                                                                        Value="Найден"/>
                                                                <Setter Property="Foreground"
                                                                        Value="{DynamicResource StatusSuccessBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                                    Value="FamilyFound">
                                                                <Setter Property="Text"
                                                                        Value="Семейство"/>
                                                                <Setter Property="Foreground"
                                                                        Value="#1A73E8"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                                    Value="Unresolved">
                                                                <Setter Property="Text"
                                                                        Value="Не найден"/>
                                                                <Setter Property="Foreground"
                                                                        Value="{DynamicResource StatusWarningBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!--
                          Action column — only unresolved rows get a button.
                          Any user can open the wizard and supply NTD data;
                          the resulting Component is created immediately
                          (NeedsAdminReview = true) so the row becomes
                          "Найден" right away without restarting the app.
                        -->
                        <GridViewColumn Header=""
                                Width="140">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type local:ProjectComponentVm}">
                                    <Button Content="Ввести данные"
                                            Padding="8,3"
                                            FontSize="11"
                                            Command="{Binding DataContext.AddComponentDataCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                    BasedOn="{StaticResource OutlineButton}">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MatchStatus}"
                                                            Value="Unresolved">
                                                        <Setter Property="Visibility"
                                                                Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MatchStatus}"
                                                            Value="FamilyFound">
                                                        <Setter Property="Visibility"
                                                                Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Divider -->
            <Border Grid.Column="1"
                    Background="{DynamicResource BorderDefaultBrush}"/>

            <!-- Detail panel -->
            <Grid Grid.Column="2"
                    Background="{DynamicResource BgSidebarBrush}">

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding SelectedComponent,
                    Converter={StaticResource NotNullToVis}}">
                    <TextBlock Text="&#xE9CE;"
                               Style="{StaticResource IconTextMuted}"
                               FontSize="32"/>
                    <TextBlock Text="Выберите компонент"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Component detail -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding SelectedComponent,
                      Converter={StaticResource NullToVis}}">

                    <Grid Background="{DynamicResource BgSidebarBrush}">
                        <StackPanel Margin="16"
                                DataContext="{Binding SelectedComponent}">

                            <TextBlock Text="{Binding Name}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding Positions}"
                                       Style="{StaticResource PositionsText}"
                                       Margin="0,0,0,16"/>

                            <!-- Unresolved / FamilyFound hint + button, mirrors the list-row action -->
                            <Border Padding="10,8"
                                    Margin="0,0,0,16"
                                    CornerRadius="6"
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                    Value="Unresolved">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                                <Setter Property="Background"
                                                        Value="{DynamicResource StatusWarningBgBrush}"/>
                                                <Setter Property="BorderBrush"
                                                        Value="{DynamicResource StatusWarningBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MatchStatus}"
                                                    Value="FamilyFound">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                                <Setter Property="Background"
                                                        Value="#E8F0FE"/>
                                                <Setter Property="BorderBrush"
                                                        Value="#4285F4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                            FontWeight="Medium"
                                            Margin="0,0,0,6">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MatchStatus}"
                                                            Value="Unresolved">
                                                        <Setter Property="Text"
                                                                Value="Компонент не найден в каталоге"/>
                                                        <Setter Property="Foreground"
                                                                Value="{DynamicResource StatusWarningBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MatchStatus}"
                                                            Value="FamilyFound">
                                                        <Setter Property="Text"
                                                                Value="Семейство найдено, но не хватает данных по компоненту"/>
                                                        <Setter Property="Foreground"
                                                                Value="#1A73E8"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Content="Ввести данные компонента"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="10,6"
                                            HorizontalAlignment="Left"
                                            Command="{Binding DataContext.AddComponentDataCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="ПАРАМЕТРЫ ПО НТД"
                                       Style="{StaticResource SectionLabel}"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="Загрузка..."
                                       Style="{StaticResource MutedText}"
                                       Visibility="{Binding IsLoadingNtd,
                               Converter={StaticResource BoolToVis}}"/>

                            <ItemsControl ItemsSource="{Binding NtdValues}"
                                          Focusable="False"
                                          Visibility="{Binding NtdLoaded,
                                  Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:NtdParameterVm}">
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding DisplayName}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       Style="{StaticResource ParamValue}"
                                                       FontSize="12"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
