<UserControl x:Class="OperationMaps.Wpf.Features.Form4.Form4View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:OperationMaps.Wpf.Features.Form4"
             mc:Ignorable="d"
             Background="White">
    <UserControl.Resources>

        <!-- Section header style -->
        <Style x:Key="SectionHeader"
                TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="10"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="#888888"/>
            <Setter Property="Margin"
                    Value="0,16,0,4"/>
        </Style>

        <!-- Parameter label style -->
        <Style x:Key="ParamLabel"
                TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="12"/>
            <Setter Property="Foreground"
                    Value="#666666"/>
            <Setter Property="TextWrapping"
                    Value="Wrap"/>
            <Setter Property="Margin"
                    Value="0,8,0,1"/>
        </Style>

        <!-- Parameter value style -->
        <Style x:Key="ParamValue"
                TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="Medium"/>
            <Setter Property="FontFamily"
                    Value="Consolas"/>
            <Setter Property="Foreground"
                    Value="#2B579A"/>
        </Style>

        <!-- List item style -->
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch"/>
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="BorderThickness"
                    Value="0,0,0,1"/>
            <Setter Property="BorderBrush"
                    Value="#F0F0F0"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#F5F7FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected"
                                    Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EBF0FB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#FAFAFA"
                BorderBrush="#EEEEEE"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel>
                <TextBlock Text="Форма 4"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#1A1A2E"/>
                <TextBlock Text="Карта оценки номенклатуры ЭРИ"
                           FontSize="11"
                           Foreground="#888888"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Loading -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Загрузка..."
                       FontSize="14"
                       Foreground="#AAAAAA"/>
        </StackPanel>

        <!-- Content -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"
                        MinWidth="180"
                        MaxWidth="360"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Groups list -->
            <ScrollViewer Grid.Column="0"
                          Background="#FAFAFA"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:Form4Group}">
                            <Border BorderBrush="#F0F0F0"
                                    BorderThickness="0,0,0,1"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectGroupCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                    Value="True">
                                                <Setter Property="Background"
                                                        Value="#F0F4FF"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsSelected}"
                                                    Value="True">
                                                <Setter Property="Background"
                                                        Value="#EBF0FB"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Margin="12,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="13"
                                                   FontWeight="Medium"
                                                   Foreground="#1A1A2E"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Positions}"
                                                   FontFamily="Consolas"
                                                   FontSize="10"
                                                   Foreground="#999999"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Ellipse Grid.Column="1"
                                             Width="7"
                                            Height="7"
                                             VerticalAlignment="Top"
                                             Margin="0,3,0,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill"
                                                        Value="#F9A825"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasNtdValues}"
                                                            Value="True">
                                                        <Setter Property="Fill"
                                                                Value="#34A853"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Divider -->
            <Border Grid.Column="1"
                    Background="#E0E0E0"/>

            <!-- Detail panel -->
            <Grid Grid.Column="2">

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding SelectedGroup,
                                Converter={StaticResource NotNullToVis}}">
                    <TextBlock Text="&#xE9D9;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="40"
                               Foreground="#DDDDDD"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Выберите компонент из списка"
                               Foreground="#BBBBBB"
                               FontSize="13"
                               Margin="0,10,0,0"/>
                </StackPanel>

                <!-- NTD detail -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Padding="24,16,24,24"
                              Visibility="{Binding SelectedGroup,
                                  Converter={StaticResource NullToVis}}">
                    <StackPanel DataContext="{Binding SelectedGroup}">

                        <!-- Component name -->
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1A1A2E"
                                   TextWrapping="Wrap"/>

                        <!-- Positions -->
                        <TextBlock Text="{Binding Positions}"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="#999999"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>

                        <!-- No NTD warning -->
                        <Border Background="#FFFBEB"
                                BorderBrush="#FDE68A"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,10"
                                Margin="0,16,0,0"
                                Visibility="{Binding HasNtdValues,
                                    Converter={StaticResource InverseBoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="#D97706"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="Параметры не найдены"
                                               FontSize="13"
                                               FontWeight="Medium"
                                               Foreground="#92400E"/>
                                    <TextBlock Text="Компонент отсутствует в каталоге ЭРИ"
                                               FontSize="11"
                                               Foreground="#B45309"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- NTD parameters -->
                        <StackPanel Visibility="{Binding HasNtdValues,
                                        Converter={StaticResource BoolToVis}}">

                            <ItemsControl ItemsSource="{Binding NtdValues}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,10,0,0">
                                            <!-- Parameter name -->
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Style="{StaticResource ParamLabel}"/>
                                            <!-- Value -->
                                            <TextBlock Text="{Binding Value}"
                                                       Style="{StaticResource ParamValue}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
