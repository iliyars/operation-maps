<UserControl x:Class="OperationMaps.Wpf.Features.OwnForm.OwnFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:OperationMaps.Wpf.Features.OwnForm"
             mc:Ignorable="d"
             Background="White">
  <UserControl.Resources>

    <Style x:Key="ToolbarButton"
           TargetType="Button">
      <Setter Property="Background"
              Value="Transparent"/>
      <Setter Property="BorderThickness"
              Value="1"/>
      <Setter Property="BorderBrush"
              Value="#DCDCDC"/>
      <Setter Property="Padding"
              Value="10,5"/>
      <Setter Property="FontSize"
              Value="12"/>
      <Setter Property="Cursor"
              Value="Hand"/>
      <Setter Property="Height"
              Value="30"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="5"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver"
                       Value="True">
                <Setter TargetName="Bd"
                        Property="Background"
                        Value="#F0F0F0"/>
              </Trigger>
              <Trigger Property="IsEnabled"
                       Value="False">
                <Setter Property="Opacity"
                        Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ParamLabel"
           TargetType="TextBlock">
      <Setter Property="FontSize"
              Value="12"/>
      <Setter Property="Foreground"
              Value="#666666"/>
      <Setter Property="TextWrapping"
              Value="Wrap"/>
      <Setter Property="Margin"
              Value="0,8,0,1"/>
    </Style>

  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <!-- header  -->
      <RowDefinition Height="Auto"/>
      <!-- toolbar -->
      <RowDefinition Height="*"/>
      <!-- content -->
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0"
            Background="#FAFAFA"
            BorderBrush="#EEEEEE"
            BorderThickness="0,0,0,1"
            Padding="16,10">
      <StackPanel>
        <TextBlock Text="{Binding FormTitle}"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="#1A1A2E"
                   TextWrapping="Wrap"/>
        <TextBlock Text="{Binding FormNumber, StringFormat='Форма {0}'}"
                   FontSize="11"
                   Foreground="#888888"
                   Margin="0,2,0,0"/>
      </StackPanel>
    </Border>

    <!-- Toolbar -->
    <Border Grid.Row="1"
            Background="#FAFAFA"
            BorderBrush="#EEEEEE"
            BorderThickness="0,0,0,1"
            Padding="12,6">
      <StackPanel Orientation="Horizontal">
        <Button Style="{StaticResource ToolbarButton}"
                Command="{Binding UndoCommand}"
                Margin="0,0,4,0"
                ToolTip="Отменить">
          <TextBlock Text="&#xE7A7;"
                     FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="13"/>
        </Button>
        <Button Style="{StaticResource ToolbarButton}"
                Command="{Binding RedoCommand}"
                Margin="0,0,12,0"
                ToolTip="Повторить">
          <TextBlock Text="&#xE7A6;"
                     FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="13"/>
        </Button>
        <Button Style="{StaticResource ToolbarButton}"
                Command="{Binding SplitCommand}"
                Margin="0,0,4,0">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xF547;"
                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>
            <TextBlock Text="Разбить"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Style="{StaticResource ToolbarButton}"
                Command="{Binding MergeCommand}"
                IsEnabled="{Binding CanMerge}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xF546;"
                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>
            <TextBlock Text="Объединить"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- Loading -->
    <StackPanel Grid.Row="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
      <TextBlock Text="Загрузка..."
                 FontSize="14"
                 Foreground="#AAAAAA"/>
    </StackPanel>

    <!-- Content: list + detail -->
    <Grid Grid.Row="2"
          Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260"
                          MinWidth="180"
                          MaxWidth="360"/>
        <ColumnDefinition Width="1"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Columns list (left) -->
      <ScrollViewer Grid.Column="0"
                    Background="#FAFAFA"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Columns}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type local:FormColumnVm}">
              <Border BorderBrush="#F0F0F0"
                      BorderThickness="0,0,0,1"
                      Cursor="Hand">
                <Border.InputBindings>
                  <MouseBinding MouseAction="LeftClick"
                                Command="{Binding DataContext.SelectColumnCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"/>
                </Border.InputBindings>
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background"
                            Value="Transparent"/>
                    <Style.Triggers>
                      <Trigger Property="IsMouseOver"
                               Value="True">
                        <Setter Property="Background"
                                Value="#F0F4FF"/>
                      </Trigger>
                      <DataTrigger Binding="{Binding IsSelected}"
                                   Value="True">
                        <Setter Property="Background"
                                Value="#EBF0FB"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <Grid Margin="12,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Name}"
                               FontSize="13"
                               FontWeight="Medium"
                               Foreground="#1A1A2E"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Positions}"
                               FontFamily="Consolas"
                               FontSize="10"
                               Foreground="#999999"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0"/>
                  </StackPanel>
                  <Ellipse Grid.Column="1"
                           Width="7"
                           Height="7"
                           Fill="#34A853"
                           VerticalAlignment="Top"
                           Margin="0,3,0,0"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Divider -->
      <Border Grid.Column="1"
              Background="#E0E0E0"/>

      <!-- Detail panel (right) -->
      <Grid Grid.Column="2">

        <!-- Empty state -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="{Binding SelectedColumn,
                                Converter={StaticResource NotNullToVis}}">
          <TextBlock Text="&#xE9D9;"
                     FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="40"
                     Foreground="#DDDDDD"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="Выберите компонент из списка"
                     Foreground="#BBBBBB"
                     FontSize="13"
                     Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Parameters -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Padding="24,16,24,24"
                      Visibility="{Binding SelectedColumn,
                                  Converter={StaticResource NullToVis}}">
          <StackPanel DataContext="{Binding SelectedColumn}">

            <!-- Component name -->
            <TextBlock Text="{Binding Name}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#1A1A2E"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding Positions}"
                       FontFamily="Consolas"
                       FontSize="11"
                       Foreground="#999999"
                       TextWrapping="Wrap"
                       Margin="0,4,0,16"/>

            <!-- Parameters list -->
            <ItemsControl ItemsSource="{Binding DataContext.ParameterDetails,
                            RelativeSource={RelativeSource AncestorType=UserControl}}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type local:ParameterDetailVm}">
                  <Border BorderBrush="#F0F0F0"
                          BorderThickness="0,0,0,1"
                          Padding="0,10,0,10">
                    <StackPanel>

                      <TextBlock Text="{Binding DisplayName}"
                                 Style="{StaticResource ParamLabel}"
                                 Margin="0"/>

                      <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- в схеме -->
                        <StackPanel Grid.Column="0"
                                    Margin="0,0,8,0">
                          <TextBlock Text="в схеме"
                                     FontSize="10"
                                     Foreground="#2B579A"
                                     FontWeight="Medium"
                                     Margin="0,0,0,3"/>
                          <!-- Editable for manual params -->
                          <TextBox Text="{Binding SchemeValue,
                                                                 UpdateSourceTrigger=PropertyChanged}"
                                   FontSize="13"
                                   Padding="6,4"
                                   BorderBrush="#DCDCDC"
                                   BorderThickness="1"
                                   Background="White"
                                   Visibility="{Binding IsDerived,
                                                                 Converter={StaticResource InverseBoolToVis}}"/>
                          <!-- Read-only for derived params -->
                          <Border Background="#F5F5F5"
                                  BorderBrush="#DCDCDC"
                                  BorderThickness="1"
                                  Padding="6,4"
                                  Visibility="{Binding IsDerived,
                                                                Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Text="{Binding SchemeValue}"
                                         FontSize="13"
                                         Foreground="#444444"/>
                              <TextBlock Text=" (авто)"
                                         FontSize="10"
                                         Foreground="#AAAAAA"
                                         VerticalAlignment="Center"/>
                            </StackPanel>
                          </Border>
                        </StackPanel>

                        <!-- по НТД -->
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="по НТД"
                                     FontSize="10"
                                     Foreground="#888888"
                                     FontWeight="Medium"
                                     Margin="0,0,0,3"/>
                          <TextBlock Text="{Binding NtdValue}"
                                     FontSize="13"
                                     FontFamily="Consolas"
                                     Foreground="#2B579A"
                                     Padding="0,4"/>
                        </StackPanel>
                      </Grid>

                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
