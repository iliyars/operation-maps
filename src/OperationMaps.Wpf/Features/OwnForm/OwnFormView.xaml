<UserControl x:Class="OperationMaps.Wpf.Features.OwnForm.OwnFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:OperationMaps.Wpf.Shared.Converters"
             xmlns:shared="clr-namespace:OperationMaps.Wpf.Shared"
             xmlns:local="clr-namespace:OperationMaps.Wpf.Features.OwnForm"
             mc:Ignorable="d"
             Background="{DynamicResource BgAppBrush}">
  <UserControl.Resources>
    <Style TargetType="ItemsControl">
      <Setter Property="FocusVisualStyle"
          Value="{x:Null}"/>
      <Setter Property="Focusable"
          Value="False"/>
    </Style>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0"
            Background="{DynamicResource BgPanelBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="{Binding FormTitle}"
              Style="{StaticResource TitleText}"/>
          <TextBlock Text="{Binding FormNumber, StringFormat='Форма {0}'}"
              Style="{StaticResource SubtitleText}"/>
        </StackPanel>
        <Button Grid.Column="1"
                Command="{Binding ExportWordCommand}"
                Style="{StaticResource PrimaryButton}"
                VerticalAlignment="Center"
                Padding="14,8">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE8A5;"
                Style="{StaticResource IconText}"
                       FontSize="14"
                VerticalAlignment="Center"
                Margin="0,0,8,0"/>
            <TextBlock VerticalAlignment="Center">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Text"
                      Value="Создать Word"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsExporting}"
                        Value="True">
                      <Setter Property="Text"
                          Value="Создание..."/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Toolbar -->
    <Border Grid.Row="1"
            Background="{DynamicResource BgPanelBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="8,4">
      <StackPanel Orientation="Horizontal">
        <Button Style="{StaticResource GhostButton}"
                Command="{Binding UndoCommand}"
                Margin="0,0,2,0"
                ToolTip="Отменить">
          <TextBlock Text="&#xE7A7;"
              Style="{StaticResource IconText}"
                     FontSize="13"
              Foreground="{DynamicResource TextPrimaryBrush}"/>
        </Button>
        <Button Style="{StaticResource GhostButton}"
                Command="{Binding RedoCommand}"
                Margin="0,0,8,0"
                ToolTip="Повторить">
          <TextBlock Text="&#xE7A6;"
              Style="{StaticResource IconText}"
                     FontSize="13"
              Foreground="{DynamicResource TextPrimaryBrush}"/>
        </Button>
        <Button Style="{StaticResource OutlineButton}"
                Command="{Binding SplitCommand}"
                Margin="0,0,4,0">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xF547;"
                Style="{StaticResource IconText}"
                       FontSize="13"
                Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                Margin="0,0,5,0"/>
            <TextBlock Text="Разбить"
                Foreground="{DynamicResource TextPrimaryBrush}"
                VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Style="{StaticResource OutlineButton}"
                Command="{Binding MergeCommand}"
                Margin="0,0,12,0">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xF546;"
                Style="{StaticResource IconText}"
                       FontSize="13"
                Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                Margin="0,0,5,0"/>
            <TextBlock Text="Объединить"
                Foreground="{DynamicResource TextPrimaryBrush}"
                VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <!-- Multi-select hint -->
        <TextBlock VerticalAlignment="Center"
                   FontSize="11"
                   Foreground="{DynamicResource TextMutedBrush}"
                   Text="{Binding SelectedColumns.Count, StringFormat='Выбрано для объединения: {0} (Ctrl+клик)'}">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility"
                  Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedColumns.Count}"
                    Value="1">
                  <Setter Property="Visibility"
                      Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedColumns.Count}"
                    Value="2">
                  <Setter Property="Visibility"
                      Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </StackPanel>
    </Border>

    <!-- Loading -->
    <StackPanel Grid.Row="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
      <TextBlock Text="Загрузка..."
          Style="{StaticResource MutedText}"
          FontSize="14"/>
    </StackPanel>

    <!-- Content -->
    <Grid Grid.Row="2"
          Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260"
            MinWidth="180"
            MaxWidth="360"/>
        <ColumnDefinition Width="1"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left: columns list -->
      <ScrollViewer Grid.Column="0"
                    Background="{DynamicResource BgSidebarBrush}"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding ColumnItems}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type local:ColumnListItemVm}">
              <Border BorderBrush="{DynamicResource BorderDefaultBrush}"
                      BorderThickness="0,0,0,1"
                      Cursor="Hand"
                      Tag="{Binding}"
                      MouseLeftButtonUp="ColumnItem_MouseLeftButtonUp">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background"
                        Value="Transparent"/>
                    <Style.Triggers>
                      <Trigger Property="IsMouseOver"
                          Value="True">
                        <Setter Property="Background"
                            Value="{DynamicResource BgHoverBrush}"/>
                      </Trigger>
                      <DataTrigger Binding="{Binding IsSelected}"
                          Value="True">
                        <Setter Property="Background"
                            Value="{DynamicResource BgActiveBrush}"/>
                      </DataTrigger>
                      <DataTrigger Binding="{Binding IsMultiSelected}"
                          Value="True">
                        <Setter Property="Background"
                            Value="{DynamicResource AccentBgBrush}"/>
                        <Setter Property="BorderBrush"
                            Value="{DynamicResource AccentBrush}"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>

                <Grid Margin="12,10">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>

                  <TextBlock Grid.Row="0"
                      Grid.Column="0"
                             Text="{Binding Name}"
                             FontSize="12"
                      FontWeight="Medium"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             TextWrapping="Wrap"/>

                  <Grid Grid.Row="0"
                      Grid.Column="1"
                      Margin="6,0,0,0">
                    <Border CornerRadius="9"
                        Width="18"
                        Height="18"
                            Background="{DynamicResource AccentBrush}"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsMultiSelected, Converter={StaticResource BoolToVis}}">
                      <TextBlock Text="&#xE73E;"
                                 FontFamily="Segoe MDL2 Assets"
                                 FontSize="11"
                                 Foreground="White"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>

                    <Border CornerRadius="10"
                        Padding="6,2"
                        VerticalAlignment="Center"
                            Visibility="{Binding IsMultiSelected, Converter={StaticResource InverseBoolToVis}}">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding FillStatus}"
                                Value="Complete">
                              <Setter Property="Background"
                                  Value="{DynamicResource StatusSuccessBgBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding FillStatus}"
                                Value="Partial">
                              <Setter Property="Background"
                                  Value="{DynamicResource StatusWarningBgBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding FillStatus}"
                                Value="Empty">
                              <Setter Property="Background"
                                  Value="{DynamicResource BgHoverBrush}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <TextBlock Text="{Binding StatusLabel}"
                          FontSize="10"
                          FontWeight="Medium">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding FillStatus}"
                                  Value="Complete">
                                <Setter Property="Foreground"
                                    Value="{DynamicResource StatusSuccessBrush}"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding FillStatus}"
                                  Value="Partial">
                                <Setter Property="Foreground"
                                    Value="{DynamicResource StatusWarningBrush}"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding FillStatus}"
                                  Value="Empty">
                                <Setter Property="Foreground"
                                    Value="{DynamicResource TextMutedBrush}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </Border>
                  </Grid>

                  <TextBlock Grid.Row="1"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                             Text="{Binding Positions}"
                             Style="{StaticResource PositionsText}"
                             Margin="0,2,0,6"/>

                  <Grid Grid.Row="2"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                      Height="4">
                    <Border Background="{DynamicResource BorderDefaultBrush}"
                        CornerRadius="2"/>
                    <Border CornerRadius="2"
                        HorizontalAlignment="Left">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding FillStatus}"
                                Value="Complete">
                              <Setter Property="Background"
                                  Value="{DynamicResource StatusSuccessBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding FillStatus}"
                                Value="Partial">
                              <Setter Property="Background"
                                  Value="{DynamicResource StatusWarningBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding FillStatus}"
                                Value="Empty">
                              <Setter Property="Background"
                                  Value="{DynamicResource TextMutedBrush}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <Border.Width>
                        <MultiBinding Converter="{StaticResource FractionToWidth}">
                          <Binding Path="ProgressFraction"/>
                          <Binding Path="ActualWidth"
                              RelativeSource="{RelativeSource AncestorType=Grid}"/>
                        </MultiBinding>
                      </Border.Width>
                    </Border>
                  </Grid>

                  <TextBlock Grid.Row="3"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                             Text="{Binding ProgressText}"
                             Style="{StaticResource MutedText}"
                             FontSize="10"
                      Margin="0,3,0,0"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Divider -->
      <Border Grid.Column="1"
          Background="{DynamicResource BorderDefaultBrush}"/>

      <!-- Right: detail panel -->
      <Grid Grid.Column="2"
          Background="{DynamicResource BgAppBrush}">

        <StackPanel VerticalAlignment="Center"
            HorizontalAlignment="Center"
                    Visibility="{Binding SelectedColumn, Converter={StaticResource NotNullToVis}}">
          <TextBlock Text="&#xE9D9;"
              Style="{StaticResource IconTextMuted}"
              FontSize="40"/>
          <TextBlock Text="Выберите компонент из списка"
                     Style="{StaticResource MutedText}"
              HorizontalAlignment="Center"
              Margin="0,10,0,0"/>
        </StackPanel>

        <Grid Visibility="{Binding SelectedColumn, Converter={StaticResource NullToVis}}">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <ScrollViewer Grid.Row="0"
              VerticalScrollBarVisibility="Auto"
              Padding="24,16,24,8">
            <StackPanel DataContext="{Binding SelectedColumn}"
                        shared:TextBoxNavigationHelper.Enable="True">

              <TextBlock Text="{Binding Name}"
                  FontSize="16"
                  FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                  TextWrapping="Wrap"/>
              <TextBlock Text="{Binding Positions}"
                  Style="{StaticResource PositionsText}"
                  Margin="0,4,0,16"/>

              <ItemsControl ItemsSource="{Binding DataContext.ParameterDetails,
                                RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type local:ParameterDetailVm}">
                    <Border BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="0,0,0,1"
                        Padding="0,10,0,10">
                      <StackPanel>

                        <StackPanel Orientation="Horizontal"
                            Margin="0,8,0,1">
                          <TextBlock Text="{Binding DisplayName}"
                              Style="{StaticResource ParamLabel}"
                              Margin="0"/>
                          <TextBlock Text=" *"
                              FontSize="12"
                                     Foreground="{DynamicResource StatusRequiredBrush}"
                                     VerticalAlignment="Top"
                                     Visibility="{Binding IsRequired, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <!-- в схеме + по НТД + номера выводов (Form 64 only — third column collapses to 0 width otherwise) -->
                        <Grid Margin="0,4,0,0">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition>
                              <ColumnDefinition.Style>
                                <Style TargetType="ColumnDefinition">
                                  <Setter Property="Width"
                                      Value="0"/>
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowPins}"
                                        Value="True">
                                      <Setter Property="Width"
                                          Value="*"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </ColumnDefinition.Style>
                            </ColumnDefinition>
                          </Grid.ColumnDefinitions>

                          <StackPanel Grid.Column="0"
                              Margin="0,0,8,0">
                            <TextBlock Text="в схеме"
                                Style="{StaticResource SectionLabel}"
                                Foreground="{DynamicResource AccentBrush}"/>
                            <TextBox Text="{Binding SchemeValue, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding IsDerived, Converter={StaticResource InverseBoolToVis}}"/>
                            <Border Background="{DynamicResource BgDerivedBrush}"
                                    BorderBrush="{DynamicResource BorderInputBrush}"
                                    BorderThickness="1"
                                Padding="6,4"
                                    Visibility="{Binding IsDerived, Converter={StaticResource BoolToVis}}">
                              <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SchemeValue}"
                                    FontSize="13"
                                    Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text=" (авто)"
                                    FontSize="10"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    VerticalAlignment="Center"/>
                              </StackPanel>
                            </Border>
                          </StackPanel>

                          <StackPanel Grid.Column="1"
                              Margin="0,0,8,0">
                            <TextBlock Text="по НТД"
                                Style="{StaticResource SectionLabel}"/>
                            <TextBlock Text="{Binding NtdValue}"
                                Style="{StaticResource ParamValue}"
                                FontSize="13"
                                Padding="0,4"/>
                          </StackPanel>

                          <!-- номера выводов — Form 64 only, read-only catalog data -->
                          <StackPanel Grid.Column="2"
                                      Visibility="{Binding ShowPins, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="№ выводов"
                                Style="{StaticResource SectionLabel}"/>
                            <TextBlock Text="{Binding PinsValue}"
                                Style="{StaticResource ParamValue}"
                                FontSize="13"
                                Padding="0,4"/>
                          </StackPanel>
                        </Grid>

                        <!-- Optional second-value row — e.g. Form 64's second supply voltage.
                             Rendered automatically when the catalog has a value for this
                             row's optional counterpart (HasOptionalRow); there's no
                             user-facing "add" button — the catalog data decides. -->
                        <Border Background="{DynamicResource BgHoverBrush}"
                                CornerRadius="6"
                            Padding="8"
                            Margin="0,8,0,0"
                                Visibility="{Binding HasOptionalRow, Converter={StaticResource BoolToVis}}">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition>
                                <ColumnDefinition.Style>
                                  <Style TargetType="ColumnDefinition">
                                    <Setter Property="Width"
                                        Value="0"/>
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding ShowPins}"
                                          Value="True">
                                        <Setter Property="Width"
                                            Value="*"/>
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </ColumnDefinition.Style>
                              </ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                Margin="0,0,8,0">
                              <TextBlock Text="второе напряжение: в схеме"
                                  Style="{StaticResource SectionLabel}"
                                  Foreground="{DynamicResource AccentBrush}"/>
                              <TextBox Text="{Binding OptionalSchemeValue, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                Margin="0,0,8,0">
                              <TextBlock Text="второе напряжение: по НТД"
                                  Style="{StaticResource SectionLabel}"/>
                              <TextBlock Text="{Binding OptionalNtdValue}"
                                  Style="{StaticResource ParamValue}"
                                  FontSize="13"
                                  Padding="0,4"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Visibility="{Binding ShowPins, Converter={StaticResource BoolToVis}}">
                              <TextBlock Text="№ выводов"
                                  Style="{StaticResource SectionLabel}"/>
                              <TextBlock Text="{Binding OptionalPinsValue}"
                                  Style="{StaticResource ParamValue}"
                                  FontSize="13"
                                  Padding="0,4"/>
                            </StackPanel>
                          </Grid>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Notes}"
                            Margin="0,6,0,0">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:OwnFormNoteVm}">
                              <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="Auto"/>
                                  <ColumnDefinition Width="*"/>
                                  <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                    Text="{Binding Marker}"
                                    Style="{StaticResource NoteMarker}"/>
                                <TextBlock Grid.Column="1"
                                    Text="{Binding NoteText}"
                                    Style="{StaticResource NoteText}"/>
                                <Button Grid.Column="2"
                                    Command="{Binding DeleteCommand}"
                                        Style="{StaticResource IconButton}"
                                    FocusVisualStyle="{x:Null}">
                                  <TextBlock Text="&#xE711;"
                                      Style="{StaticResource IconText}"
                                             FontSize="10"
                                      Foreground="{DynamicResource TextMutedBrush}"/>
                                </Button>
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,6,0,0"
                            Visibility="{Binding IsAddingNote, Converter={StaticResource BoolToVis}}">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <TextBox Grid.Column="0"
                                   Text="{Binding PendingNoteText, UpdateSourceTrigger=PropertyChanged}"
                                   AcceptsReturn="False"
                                   IsVisibleChanged="NoteInputBox_IsVisibleChanged">
                            <TextBox.InputBindings>
                              <KeyBinding Key="Enter"
                                  Command="{Binding ConfirmAddNoteCommand}"/>
                              <KeyBinding Key="Escape"
                                  Command="{Binding CancelAddNoteCommand}"/>
                            </TextBox.InputBindings>
                          </TextBox>
                          <Button Grid.Column="1"
                              Command="{Binding ConfirmAddNoteCommand}"
                                  Style="{StaticResource PrimaryButton}"
                              Margin="4,0,0,0"
                              Height="Auto"
                              Padding="8,4">
                            <TextBlock Text="ОК"/>
                          </Button>
                          <Button Grid.Column="2"
                              Command="{Binding CancelAddNoteCommand}"
                                  Style="{StaticResource OutlineButton}"
                              Margin="4,0,0,0"
                              Height="Auto"
                              Padding="8,4">
                            <TextBlock Text="✕"
                                Foreground="{DynamicResource TextSecondaryBrush}"/>
                          </Button>
                        </Grid>

                        <Button Command="{Binding StartAddNoteCommand}"
                                Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Left"
                            Padding="0"
                            Margin="0,4,0,0"
                                Visibility="{Binding IsAddingNote, Converter={StaticResource InverseBoolToVis}}">
                          <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;"
                                Style="{StaticResource IconText}"
                                       FontSize="10"
                                Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"
                                Margin="0,0,4,0"/>
                            <TextBlock Text="Добавить примечание"
                                FontSize="11"
                                Foreground="{DynamicResource TextMutedBrush}"/>
                          </StackPanel>
                        </Button>

                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

            </StackPanel>
          </ScrollViewer>

          <!-- Save button -->
          <Border Grid.Row="1"
                  Background="{DynamicResource BgPanelBrush}"
                  BorderBrush="{DynamicResource BorderDefaultBrush}"
                  BorderThickness="0,1,0,0"
                  Padding="16,10">
            <Button Command="{Binding SaveColumnCommand}"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Right"
                Height="36"
                Padding="20,0">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE74E;"
                    Style="{StaticResource IconTextOnAccent}"
                           FontSize="13"
                    VerticalAlignment="Center"
                    Margin="0,0,6,0"/>
                <TextBlock Text="Сохранить"
                    Foreground="{DynamicResource AccentTextBrush}"
                    VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </Border>

        </Grid>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
