<Window x:Class="OperationMaps.Wpf.Features.OwnForm.SplitDialog.SplitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OperationMaps.Wpf.Features.OwnForm.SplitDialog"
        mc:Ignorable="d"
        Title="Разбить компонент"
        Width="800"
        MinWidth="600"
        Height="500"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
  <Window.Resources>

    <!-- Drag source style — position pill -->
    <Style x:Key="PositionPill"
           TargetType="Border">
      <Setter Property="Background"
              Value="#EBF0FB"/>
      <Setter Property="BorderBrush"
              Value="#C5D3F5"/>
      <Setter Property="BorderThickness"
              Value="1"/>
      <Setter Property="CornerRadius"
              Value="4"/>
      <Setter Property="Padding"
              Value="8,3"/>
      <Setter Property="Margin"
              Value="3"/>
      <Setter Property="Cursor"
              Value="Hand"/>
    </Style>

    <!-- Drop target list style -->
    <Style x:Key="DropList"
           TargetType="ListBox">
      <Setter Property="BorderBrush"
              Value="#DCDCDC"/>
      <Setter Property="BorderThickness"
              Value="1"/>
      <Setter Property="Background"
              Value="White"/>
      <Setter Property="Padding"
              Value="4"/>
      <Setter Property="MinHeight"
              Value="200"/>
      <Setter Property="AllowDrop"
              Value="True"/>
    </Style>

  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <!-- header         -->
      <RowDefinition Height="*"/>
      <!-- lists          -->
      <RowDefinition Height="Auto"/>
      <!-- footer buttons -->
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0"
                Margin="0,0,0,12">
      <TextBlock Text="Распределите позиции по группам"
                 FontSize="14"
                 FontWeight="SemiBold"
                 Foreground="#1A1A2E"/>
      <TextBlock Margin="0,4,0,0"
                 FontSize="12"
                 Foreground="#888888">
                <Run Text="Не распределено: "/>
                <Run Text="{Binding UnassignedCount, Mode=OneWay}"
                     Foreground="#E53935"/>
      </TextBlock>
    </StackPanel>

    <!-- Lists area -->
    <ScrollViewer Grid.Row="1"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled">
      <StackPanel Orientation="Horizontal">

        <!-- Source list -->
        <Border Width="160"
                BorderBrush="#DCDCDC"
                BorderThickness="1"
                CornerRadius="6"
                Margin="0,0,8,0"
                Background="White">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#F5F5F5"
                    CornerRadius="6,6,0,0"
                    Padding="10,6">
              <TextBlock Text="Нераспределённые"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="#666666"/>
            </Border>

            <ItemsControl Grid.Row="1"
                          x:Name="SourceList"
                          ItemsSource="{Binding SourcePositions}"
                          AllowDrop="True"
                          Padding="4"
                          MinHeight="200">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type local:PositionItemVm}">
                  <Border Style="{StaticResource PositionPill}"
                          x:Name="Pill"
                          PreviewMouseLeftButtonDown="Pill_MouseLeftButtonDown">
                    <TextBlock Text="{Binding Value}"
                               FontFamily="Consolas"
                               FontSize="12"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>
        </Border>

        <!-- Groups -->
        <ItemsControl ItemsSource="{Binding Groups}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type local:SplitGroupVm}">
              <Border Width="160"
                      BorderBrush="#DCDCDC"
                      BorderThickness="1"
                      CornerRadius="6"
                      Margin="0,0,8,0"
                      Background="White"
                      x:Name="GroupBorder"
                      AllowDrop="True"
                      DragOver="GroupBorder_DragOver"
                      Drop="GroupBorder_Drop">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>

                  <!-- Group header -->
                  <Border Grid.Row="0"
                          Background="#F0F4FF"
                          CornerRadius="6,6,0,0"
                          Padding="10,6">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0"
                                 Text="{Binding Name}"
                                 FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="#2B579A"
                                 VerticalAlignment="Center"/>
                      <!-- Remove group button (only if > 2 groups) -->
                      <Button Grid.Column="1"
                              Command="{Binding RemoveCommand}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="2"
                              Cursor="Hand"
                              ToolTip="Удалить группу">
                        <TextBlock Text="&#xE711;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="10"
                                   Foreground="#AAAAAA"/>
                      </Button>
                    </Grid>
                  </Border>

                  <!-- Drop area -->
                  <ItemsControl Grid.Row="1"
                                ItemsSource="{Binding Positions}"
                                Padding="4"
                                MinHeight="200">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type local:PositionItemVm}">
                        <Border Style="{StaticResource PositionPill}"
                                x:Name="Pill"
                                PreviewMouseLeftButtonDown="Pill_MouseLeftButtonDown">
                          <TextBlock Text="{Binding Value}"
                                     FontFamily="Consolas"
                                     FontSize="12"/>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Add group button -->
        <Border Width="50"
                BorderBrush="#DCDCDC"
                BorderThickness="1"
                CornerRadius="6"
                Background="#FAFAFA"
                Margin="0,0,0,0">
          <Button Command="{Binding AddGroupCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Cursor="Hand"
                  ToolTip="Добавить группу"
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock Text="&#xE710;"
                         FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                         FontSize="20"
                         Foreground="#AAAAAA"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="Группа"
                         FontSize="10"
                         Foreground="#AAAAAA"
                         HorizontalAlignment="Center"
                         Margin="0,4,0,0"/>
            </StackPanel>
          </Button>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- Footer -->
    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Content="Отмена"
              Width="90"
              Height="32"
              IsCancel="True"
              Margin="0,0,8,0"
              Click="CancelButton_Click"/>
      <Button x:Name="OkButton"
              Content="Разбить"
              Width="90"
              Height="32"
              IsDefault="True"
              IsEnabled="{Binding CanConfirm}"
              Background="#2B579A"
              Foreground="White"
              BorderThickness="0"
              Click="OkButton_Click"/>
    </StackPanel>
  </Grid>
</Window>

