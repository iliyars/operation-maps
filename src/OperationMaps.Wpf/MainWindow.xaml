<Window x:Class="OperationMaps.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:OperationMaps.Wpf.Views"
        Title="OperationMaps — Карты рабочих режимов ЭРИ"
        Height="620"
        Width="1000"
        MinHeight="400"
        MinWidth="700">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="#2B579A"
            Padding="12,8">
      <TextBlock Text="Справочник ЭРИ"
                 Foreground="White"
                 FontSize="15"
                 FontWeight="SemiBold"/>
    </Border>

    <!-- ★ убрали ContentPresenter, заменили на ContentControl с x:Name -->
    <ContentControl Grid.Row="1"
                    x:Name="MainContent"/>
  </Grid>
</Window>
