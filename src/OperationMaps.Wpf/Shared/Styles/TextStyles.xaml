<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- ── Page title (Form title) ──────────────────────────────────────── -->
  <Style x:Key="TitleText"
      TargetType="TextBlock">
    <Setter Property="FontSize"
        Value="15"/>
    <Setter Property="FontWeight"
        Value="SemiBold"/>
    <Setter Property="Foreground"
        Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="TextWrapping"
        Value="Wrap"/>
  </Style>

  <!-- ── Subtitle ─────────────────────────────────────────────────────── -->
  <Style x:Key="SubtitleText"
      TargetType="TextBlock">
    <Setter Property="FontSize"
        Value="11"/>
    <Setter Property="Foreground"
        Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="Margin"
        Value="0,2,0,0"/>
  </Style>

  <!-- ── Section label (ПАРАМЕТРЫ ПО НТД) ────────────────────────────── -->
  <Style x:Key="SectionLabel"
      TargetType="TextBlock">
    <Setter Property="FontSize"
        Value="10"/>
    <Setter Property="FontWeight"
        Value="SemiBold"/>
    <Setter Property="Foreground"
        Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="Margin"
        Value="0,0,0,3"/>
  </Style>

  <!-- ── Parameter label ──────────────────────────────────────────────── -->
  <Style x:Key="ParamLabel"
      TargetType="TextBlock">
    <Setter Property="FontSize"
        Value="12"/>
    <Setter Property="Foreground"
        Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="TextWrapping"
        Value="Wrap"/>
    <Setter Property="Margin"
        Value="0,8,0,1"/>
  </Style>

  <!-- ── Parameter value (НТД, Consolas) ─────────────────────────────── -->
  <Style x:Key="ParamValue"
      TargetType="TextBlock">
    <Setter Property="FontSize"
        Value="13"/>
    <Setter Property="FontFamily"
        Value="Consolas"/>
    <Setter Property="Foreground"
        Value="{DynamicResource TextLinkBrush}"/>
  </Style>

  <!-- ── Muted text (позиции, подсказки) ──────────────────────────────── -->
  <Style x:Key="MutedText"
      TargetType="TextBlock">
    <Setter Property="FontSize"
        Value="11"/>
        <Setter Property="FontStyle"
             Value="Italic"/>
        <Setter Property="Foreground"
        Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="TextWrapping"
        Value="Wrap"/>
  </Style>

  <!-- ── Positions (Consolas, мелкий) ─────────────────────────────────── -->
  <Style x:Key="PositionsText"
      TargetType="TextBlock">
    <Setter Property="FontFamily"
        Value="Consolas"/>
    <Setter Property="FontSize"
        Value="10"/>
    <Setter Property="Foreground"
        Value="{DynamicResource TextMutedBrush}"/>
    <Setter Property="TextWrapping"
        Value="Wrap"/>
  </Style>

  <!-- ── Note marker (* **) ───────────────────────────────────────────── -->
  <Style x:Key="NoteMarker"
      TargetType="TextBlock">
    <Setter Property="FontSize"
        Value="11"/>
    <Setter Property="Foreground"
        Value="{DynamicResource TextLinkBrush}"/>
    <Setter Property="VerticalAlignment"
        Value="Top"/>
    <Setter Property="Margin"
        Value="0,0,4,0"/>
  </Style>

  <!-- ── Note text ─────────────────────────────────────────────────────── -->
  <Style x:Key="NoteText"
      TargetType="TextBlock">
    <Setter Property="FontSize"
        Value="11"/>
    <Setter Property="Foreground"
        Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="TextWrapping"
        Value="Wrap"/>
  </Style>

    <!-- ── Segoe icon ────────────────────────────────────────────────────── -->
    <Style x:Key="IconText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="IconTextMuted" TargetType="TextBlock" BasedOn="{StaticResource IconText}">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    </Style>

    <Style x:Key="IconTextOnAccent" TargetType="TextBlock" BasedOn="{StaticResource IconText}">
        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
    </Style>

</ResourceDictionary>
