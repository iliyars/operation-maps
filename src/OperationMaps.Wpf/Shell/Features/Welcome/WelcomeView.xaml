<UserControl x:Class="OperationMaps.Wpf.Shell.Features.Welcome.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OperationMaps.Wpf.Shell.Features.Welcome"
             mc:Ignorable="d" 
             Background="White"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="&#xE8FD;"
                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                       FontSize="48"
                       Foreground="#2B579A"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20" />

            <TextBlock Text="OperationMaps"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#1A1A2E"
                       HorizontalAlignment="Center" />

            <TextBlock Text="Карты рабочих режимов ЭРИ"
                       FontSize="14"
                       Foreground="#888888"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
