<UserControl x:Class="OperationMaps.Wpf.Shell.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OperationMaps.Wpf.Shell"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>

        <!-- Section separator -->
        <DataTemplate x:Key="SeparatorTemplate"
                      DataType="{x:Type local:NavItemViewModel}">
            <TextBlock Text="{Binding Label}"
                       Foreground="#888888"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Margin="12,14,12,4" />
        </DataTemplate>

        <!-- Clickable nav item -->
        <DataTemplate x:Key="NavItemTemplate"
                      DataType="{x:Type local:NavItemViewModel}">
            <Button Command="{Binding Command}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                    Height="36"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalContentAlignment="Stretch">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="6,1">
                            <Grid Margin="10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Icon}"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="14"
                                           Foreground="{Binding IsActive, Converter={StaticResource BoolToNavFg}}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Label}"
                                           FontSize="13"
                                           Foreground="{Binding IsActive, Converter={StaticResource BoolToNavFg}}"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#ECECF0" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsActive}"
                                         Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#DCE6F5" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <!-- Selector -->
        <local:NavItemTemplateSelector x:Key="NavItemSelector"
                                       SeparatorTemplate="{StaticResource SeparatorTemplate}"
                                       NavItemTemplate="{StaticResource NavItemTemplate}" />

    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Side panel -->
        <Grid Grid.Column="0"
              Background="#F5F5F7">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#2B579A"
                    Padding="14,12">
                <TextBlock Text="OperationMaps"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold" />
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,6">
                <ItemsControl ItemsSource="{Binding NavItems}"
                              ItemTemplateSelector="{StaticResource NavItemSelector}" />
            </ScrollViewer>
        </Grid>

        <!-- Divider -->
        <Border Grid.Column="1"
                Background="#DCDCDC" />

        <!-- Content -->
        <ContentControl Grid.Column="2"
                        Content="{Binding CurrentScreen}" />
    </Grid>
</UserControl>
