<UserControl x:Class="OperationMaps.Wpf.Views.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OperationMaps.Wpf.ViewModels">

  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <Style x:Key="PanelHeader"
           TargetType="TextBlock">
      <Setter Property="FontWeight"
              Value="SemiBold"/>
      <Setter Property="FontSize"
              Value="13"/>
      <Setter Property="Margin"
              Value="0,0,0,6"/>
    </Style>
    <Style x:Key="SectionHeader"
           TargetType="TextBlock">
      <Setter Property="FontWeight"
              Value="SemiBold"/>
      <Setter Property="FontSize"
              Value="12"/>
      <Setter Property="Foreground"
              Value="#555"/>
      <Setter Property="Margin"
              Value="0,10,0,4"/>
    </Style>
    <Style x:Key="ToolBtn"
           TargetType="Button">
      <Setter Property="Padding"
              Value="8,3"/>
      <Setter Property="Margin"
              Value="0,0,4,0"/>
    </Style>
    <Style x:Key="RemoveBtn"
           TargetType="Button">
      <Setter Property="Padding"
              Value="4,1"/>
      <Setter Property="Foreground"
              Value="#C00"/>
      <Setter Property="Background"
              Value="Transparent"/>
      <Setter Property="BorderThickness"
              Value="0"/>
      <Setter Property="Cursor"
              Value="Hand"/>
      <Setter Property="Content"
              Value="✕"/>
      <Setter Property="ToolTip"
              Value="Удалить примечание"/>
    </Style>
  </UserControl.Resources>

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="200"
                          MinWidth="140"/>
        <ColumnDefinition Width="5"/>
        <ColumnDefinition Width="200"
                          MinWidth="140"/>
        <ColumnDefinition Width="5"/>
        <ColumnDefinition Width="*"
                          MinWidth="260"/>
      </Grid.ColumnDefinitions>

      <!-- ── Панель 1: Типы ─────────────────────────────────────────── -->
      <DockPanel Grid.Column="0">
        <TextBlock DockPanel.Dock="Top"
                   Style="{StaticResource PanelHeader}"
                   Text="Типы компонентов"/>
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    Margin="0,6,0,0">
          <Button Style="{StaticResource ToolBtn}"
                  Content="+ Добавить"
                  Command="{Binding AddTypeCommand}"/>
          <Button Style="{StaticResource ToolBtn}"
                  Content="Сохранить"
                  Command="{Binding RenameTypeCommand}"
                  IsEnabled="{Binding HasSelectedType}"/>
          <Button Style="{StaticResource ToolBtn}"
                  Content="Удалить"
                  Command="{Binding DeleteTypeCommand}"/>
        </StackPanel>
        <ListBox ItemsSource="{Binding ComponentTypes}"
                 SelectedItem="{Binding SelectedType}"
                 SelectionMode="Single">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                       BorderThickness="0"
                       Background="Transparent"/>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>

      <GridSplitter Grid.Column="1"
                    Width="5"
                    HorizontalAlignment="Stretch"/>

      <!-- ── Панель 2: Семейства ────────────────────────────────────── -->
      <DockPanel Grid.Column="2">
        <TextBlock DockPanel.Dock="Top"
                   Style="{StaticResource PanelHeader}"
                   Text="Семейства"/>
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    Margin="0,6,0,0">
          <Button Style="{StaticResource ToolBtn}"
                  Content="+ Добавить"
                  Command="{Binding AddFamilyCommand}"/>
          <Button Style="{StaticResource ToolBtn}"
                  Content="Сохранить"
                  Command="{Binding RenameFamilyCommand}"
                  IsEnabled="{Binding HasSelectedFamily}"/>
          <Button Style="{StaticResource ToolBtn}"
                  Content="Удалить"
                  Command="{Binding DeleteFamilyCommand}"/>
        </StackPanel>
        <ListBox ItemsSource="{Binding Families}"
                 SelectedItem="{Binding SelectedFamily}"
                 SelectionMode="Single">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                       BorderThickness="0"
                       Background="Transparent"/>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>

      <GridSplitter Grid.Column="3"
                    Width="5"
                    HorizontalAlignment="Stretch"/>

      <!-- ── Панель 3: NTD + Примечания ────────────────────────────── -->
      <DockPanel Grid.Column="4">
        <TextBlock DockPanel.Dock="Top"
                   Style="{StaticResource PanelHeader}"
                   Text="Значения по НТД (Форма 4)"/>

        <!-- Секция примечаний — внизу, фиксированная высота -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="#DDD"
                Padding="0,8,0,0"
                Margin="0,8,0,0">
          <StackPanel>

            <TextBlock Style="{StaticResource SectionHeader}"
                       Text="Примечания семейства"/>

            <!-- Список привязанных примечаний -->
            <ItemsControl ItemsSource="{Binding FamilyNotes}"
                          Margin="0,0,0,8">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:FamilyNoteVm}">
                  <Border Margin="0,0,0,4"
                          Padding="6,4"
                          Background="#F8F8F8"
                          BorderBrush="#E0E0E0"
                          BorderThickness="1"
                          CornerRadius="3">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>

                      <!-- Параметр к которому относится -->
                      <TextBlock Grid.Column="0"
                                 Text="{Binding SelectedParameterName}"
                                 FontWeight="SemiBold"
                                 Foreground="#2B579A"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 MaxWidth="120"
                                 TextTrimming="CharacterEllipsis"
                                 ToolTip="{Binding SelectedParameterName}"/>

                      <!-- Текст примечания -->
                      <TextBlock Grid.Column="1"
                                 Text="{Binding NoteText}"
                                 TextWrapping="Wrap"
                                 Foreground="#333"
                                 VerticalAlignment="Center"/>

                      <!-- Кнопка удаления -->
                      <Button Grid.Column="2"
                              Style="{StaticResource RemoveBtn}"
                              Command="{Binding DataContext.RemoveNoteFromFamilyCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Строка добавления нового примечания -->
            <Border Padding="6,6"
                    Background="#F0F4FA"
                    BorderBrush="#C8D8F0"
                    BorderThickness="1"
                    CornerRadius="3">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Выбор параметра -->
                <Grid Grid.Row="0"
                      Margin="0,0,0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             Text="Параметр:"
                             VerticalAlignment="Center"
                             Foreground="#555"/>
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding AvailableParameters}"
                            SelectedItem="{Binding NewNoteParameter}"
                            DisplayMemberPath="Name"/>
                </Grid>

                <!-- Выбор примечания из справочника -->
                <Grid Grid.Row="1"
                      Margin="0,0,0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             Text="Примечание:"
                             VerticalAlignment="Center"
                             Foreground="#555"/>
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding AvailableNotes}"
                            SelectedItem="{Binding NewNote}"
                            DisplayMemberPath="Text"/>
                </Grid>

                <!-- Кнопки -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal">
                  <Button Content="+ Привязать"
                          Command="{Binding AddNoteToFamilyCommand}"
                          Padding="8,3"
                          Margin="0,0,6,0"/>
                  <Button Content="+ Новое в справочнике..."
                          Padding="8,3"
                          Click="OnCreateNoteClick"/>
                </StackPanel>
              </Grid>
            </Border>

          </StackPanel>
        </Border>

        <!-- Кнопка сохранить NTD -->
        <Button DockPanel.Dock="Bottom"
                Content="💾 Сохранить NTD"
                HorizontalAlignment="Left"
                Margin="0,6,0,0"
                Padding="10,4"
                Command="{Binding SaveNtdCommand}"/>

        <!-- Таблица NTD -->
        <DataGrid ItemsSource="{Binding NtdRows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  RowHeaderWidth="0">
          <DataGrid.Columns>
            <DataGridTextColumn Header="№"
                                Binding="{Binding RowNumber}"
                                Width="36"
                                IsReadOnly="True"/>
            <DataGridTextColumn Header="Параметр"
                                Binding="{Binding ParameterName}"
                                Width="*"
                                IsReadOnly="True"/>
            <DataGridTextColumn Header="Ед."
                                Binding="{Binding Unit}"
                                Width="70"
                                IsReadOnly="True"/>
            <DataGridTextColumn Header="Значение"
                                Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                Width="140"/>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </Grid>

    <!-- Строка статуса -->
    <Border Grid.Row="1"
            BorderThickness="0,1,0,0"
            BorderBrush="#DDD"
            Margin="0,8,0,0"
            Padding="0,4,0,0">
      <StackPanel Orientation="Horizontal">
        <ProgressBar Width="14"
                     Height="14"
                     IsIndeterminate="True"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                     Margin="0,0,8,0"/>
        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="#555"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
